{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lume",
  "version": "0.6.0",
  "identifier": "com.yefclub.lume",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lume",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Yefclub/lume/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMjRDQ0I4OUY1OTIyNzAKUldSd0lsbWZ1TXdrdmhQWWw1QWtWZW0rQTF6d3M5V1RtMHB1Y2FNUTBTejl4TkMyYkdlOHQ1c28K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
